# Convex deployment URL (auto-populated by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=

# Clerk
# Create a Clerk JWT template named "convex" with audience "convex".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# OpenAI API key — set this in the Convex Dashboard
# Settings > Environment Variables > OPENAI_API_KEY

# Optional one-time migration gate for pre-auth rows.
# Set in Convex env, not in the browser app:
# LEGACY_DATA_CLAIM_USER_IDS=https://your-clerk-issuer|user_yourClerkUserId
