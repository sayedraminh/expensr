# Convex deployment URL (auto-populated by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=

# Clerk
# Create a Clerk JWT template named "convex" with audience "convex".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# OpenAI API key — set this in the Convex Dashboard
# Settings > Environment Variables > OPENAI_API_KEY

# Plaid - set these in the Convex Dashboard, not in the browser app
# Settings > Environment Variables
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_TOKEN_ENCRYPTION_SECRET=generate-a-random-secret-at-least-32-characters
# Optional:
# PLAID_CLIENT_NAME=Extracker
# PLAID_PRODUCTS=transactions
# PLAID_COUNTRY_CODES=US
# PLAID_DAYS_REQUESTED=180
# PLAID_LINK_CUSTOMIZATION_NAME=default

# Stripe revenue sync - user API keys are entered in the app and encrypted in Convex.
# Required in Convex env:
# STRIPE_KEY_ENCRYPTION_SECRET=generate-a-random-secret-at-least-32-characters
# Optional:
# STRIPE_INITIAL_SYNC_DAYS=

# Optional one-time migration gate for pre-auth rows.
# Set in Convex env, not in the browser app:
# LEGACY_DATA_CLAIM_USER_IDS=https://your-clerk-issuer|user_yourClerkUserId
